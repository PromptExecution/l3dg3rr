#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
MSG="$(head -n1 "$MSG_FILE")"

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'

if [[ ! "$MSG" =~ $PATTERN ]]; then
  echo "commit-msg hook: message must follow Conventional Commits."
  echo "Example: feat(phase-06): add ci workflow and release automation"
  exit 1
fi

